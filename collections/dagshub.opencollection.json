        {
          "info": {
            "name": "Create a repository for the authenticated user",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://dagshub.com/api/v1/user/repos",
            "body": {
              "type": "json",
              "data": "{}"
